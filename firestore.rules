rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Retrieve verified user profile from DB
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userProfileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // RBAC Checks
    function isAdmin() {
      return isSignedIn() && userProfileExists() && getUserData().role == 'ADMIN';
    }

    function isInternal() {
      return isSignedIn() && userProfileExists() && getUserData().role == 'TEAM_INTERNAL';
    }

    function isViewer() {
      return isSignedIn() && userProfileExists() && getUserData().role == 'VIEWER';
    }

    // --- 2. Users Collection (Secure Split Access / PII Protection) ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      // Prevent Self-Assigned Roles & Privilege Escalation
      allow create: if isSignedIn() && request.auth.uid == userId 
        && incoming().role in ['ADMIN', 'TEAM_INTERNAL', 'VIEWER']
        && incoming().email is string && incoming().email.size() <= 128
        && incoming().name is string && incoming().name.size() <= 128;
        
      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().email == existing().email
        && incoming().role == existing().role  // Block self-escalating role
        && incoming().name is string && incoming().name.size() <= 128;
        
      allow delete: if isSignedIn() && isAdmin();
    }

    // --- 3. Programs Collection (Write-Access for Admin/Internal, Read-Only for Viewer) ---
    
    function isValidProgram(data) {
      return data.topic is string && data.topic.size() <= 2000
        && data.cluster in ['Strategic Transformation', 'Corporate Culture', 'Change Management', 'Investment Governance', 'Corporate Insight']
        && data.owner is string && data.owner.size() <= 512
        && data.ztRole is string && data.ztRole.size() <= 128
        && data.phase is string && data.phase.size() <= 128
        && data.progress is number && data.progress >= 0 && data.progress <= 100
        && data.statusTracker in ['Green', 'Yellow', 'Red', 'Blocked']
        && data.priority in ['Critical', 'High', 'Medium', 'Low'];
    }

    match /programs/{programId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && (isAdmin() || isInternal()) 
        && isValidId(programId) 
        && isValidProgram(incoming());
        
      allow update: if isSignedIn() && (isAdmin() || isInternal())
        && isValidProgram(incoming())
        // Enforce field constraints during update (immutability of id/no if present)
        && (!('id' in incoming()) || incoming().id == existing().id)
        && (!('no' in incoming()) || incoming().no == existing().no);
        
      allow delete: if isSignedIn() && isAdmin();
    }

    // --- 4. Meeting Logs Collection (Write-Once / Non-Editable Audit Logs) ---
    
    function isValidMeetingLog(data) {
      return data.programId is string && data.programId.size() <= 128
        && data.programTitle is string && data.programTitle.size() <= 1000
        && data.meetingDate is string && data.meetingDate.size() <= 64
        && data.notes is string && data.notes.size() <= 5000
        && data.previousStatus in ['Green', 'Yellow', 'Red', 'Blocked']
        && data.newStatus in ['Green', 'Yellow', 'Red', 'Blocked']
        && data.previousProgress is number && data.previousProgress >= 0 && data.previousProgress <= 100
        && data.newProgress is number && data.newProgress >= 0 && data.newProgress <= 100
        && data.recordedBy is string && data.recordedBy.size() <= 128;
    }

    match /meeting_logs/{logId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Allow creation only, prevent any modification or deletion to maintain log integrity (Pillar 4/7)
      allow create: if isSignedIn() && (isAdmin() || isInternal())
        && isValidId(logId)
        && isValidMeetingLog(incoming());
        
      allow update, delete: if false;
    }

    // --- 5. Cloud Documents Collection (Write-Access for Admin/Internal, Read-Only for Viewer) ---
    
    function isValidCloudDocument(data) {
      return data.tanggalSurat is string && data.tanggalSurat.size() <= 64
        && data.noSurat is string && data.noSurat.size() <= 256
        && data.asalSurat is string && data.asalSurat.size() <= 512
        && data.prihal is string && data.prihal.size() <= 2000;
    }

    match /cloud_documents/{docId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && (isAdmin() || isInternal())
        && isValidId(docId)
        && isValidCloudDocument(incoming());
        
      allow update: if isSignedIn() && (isAdmin() || isInternal())
        && isValidCloudDocument(incoming());
        
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
